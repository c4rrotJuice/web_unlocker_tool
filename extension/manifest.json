{
  "manifest_version": 3,
  "name": "Web Unlocker Tool",
  "version": "0.1.0",
  "description": "Authenticate with Supabase and check extension unlock usage.",
  "action": {
    "default_title": "Web Unlocker"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://web-unlocker-tool.onrender.com/*",
    "https://lrdpstewxrufbbgxfcgk.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/unlock_content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "images/writior_logo_48.jpg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Writior Extension",
  "version": "0.0.0",
  "description": "Canonical MV3 extension skeleton for the Writior v2 rebuild.",
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "Writior",
    "default_icon": {
      "16": "assets/icons/writior_logo_32.jpg",
      "32": "assets/icons/writior_logo_32.jpg",
      "48": "assets/icons/writior_logo_48.jpg",
      "128": "assets/icons/writior_logo_128.jpg"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "permissions": [
    "alarms",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://app.writior.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/bundle.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "assets/icons/writior_logo_32.jpg",
    "32": "assets/icons/writior_logo_32.jpg",
    "48": "assets/icons/writior_logo_48.jpg",
    "128": "assets/icons/writior_logo_128.jpg"
  }
}
